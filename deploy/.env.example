# Production .env – copy to repo root as .env (do not commit).
# Required for: docker compose -f docker-compose.prod.yml up

# Postgres (used by postgres + backend services)
POSTGRES_USER=letschat
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=letschat

# Backend (JWT, CORS, etc.) – set in same .env
JWT_SECRET=change-me-to-a-long-random-string
REFRESH_TOKEN_SECRET=change-me-to-another-long-random-string
FRONTEND_URL=https://your-frontend-domain.com || http://localhost:3000

# Optional: Google OAuth, SMTP (see backend/.env.example)
# GOOGLE_CLIENT_ID=
# SMTP_HOST= SMTP_PORT= SMTP_USER= SMTP_PASS= SMTP_FROM=

# Optional: uploads and API URL
# UPLOAD_DIR=./uploads
# API_URL=https://api.yourdomain.com
